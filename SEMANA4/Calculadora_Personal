#Pedir dos numeros enteros
#Calcular la suma, resta, multiplicacion, division, division entera, residuo, y potencia
#Comparar si la suma es >100


num1=int(input("Ingrese el primer numero"))
num2=int(input("Ingrese el segundo numero "))

suma= num1 + num2
resta= num1 - num2
mult= num1 * num2
div= num1 / num2
div_entera= num1 // num2
residuo= num1 % num2
potencia= num1 ** num2 

print ("suma;",suma )
print ("resta;", resta)
print ("mult;", mult)
print ("div;", div)
print ("div_entera;", div_entera)
print ("residuo;", residuo)
print ("potencia;", potencia)

resultado= suma > 100

print ("La suma es mayor que 100?:", resultado)
