#  Índice de Masa Corporal
#El programa debe indicar el peso, y la altura de la persona
peso = float(input("Peso (kg): "))
altura = float(input("Altura (m): "))

imc = (peso / (altura ** 2), 2)

if imc < 18.5:
    categoria = "Bajo peso"
elif 18.5 <= imc <= 24.9:
    categoria = "Normal"
elif 25 <= imc <= 29.9:
    categoria = "Sobrepeso"
else:
    categoria = "Obesidad"

print("IMC: {imc} -> '{categoria}'")
